{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/post-edit-format.js"
          }
        ],
        "description": "Auto-format JS/TS files after edits (auto-detects Biome or Prettier)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/post-edit-typecheck.js"
          }
        ],
        "description": "TypeScript type check after editing .ts/.tsx files"
      }
    ]
  }
}
